{
  "name": "wardy",
  "displayName": "wardy",
  "description": "wardy VS Code extension",
  "version": "0.0.2",
  "publisher": "Wardy",
  "repository": {
    "type": "git",
    "url": "https://github.com/codlur/wardy-ext"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:wardy.sidebar"
  ],
  "icon": "src/wardyext.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wardy-sidebar",
          "title": "Wardy",
          "icon": "src/wardyext.png"
        }
      ]
    },
    "views": {
      "wardy-sidebar": [
        {
          "type": "tree",
          "id": "wardy.sidebar",
          "name": "Wardy"
        }
      ]
    },
    "commands": [
      {
        "command": "wardy.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.98.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}

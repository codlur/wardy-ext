{
  "name": "wardy",
  "displayName": "Wardy - agentic interaction data Collector",
  "description": "Wardy - agentic interaction data Collector",
  "version": "0.3.0",
  "publisher": "Wardy",
  "license": "MIT",
  "homepage": "https://wardy.run",
  "repository": {
    "type": "git",
    "url": "https://github.com/codlur/wardy-ext"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "AI",
    "Data Science",
    "Machine Learning",
    "Visualization"
  ],
  "keywords": [
    "ai",
    "claude",
    "openai",
    "anthropic",
    "copilot",
    "agent",
    "data",
    "tracking",
    "prompt",
    "session",
    "timeline",
    "productivity"
  ],
  "activationEvents": [
    "onView:wardy.sidebar"
  ],
  "icon": "src/wardylogo.png",
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Wardy",
      "properties": {
    "wardy.storagePath": {
      "type": "string",
      "default": "",
      "description": "Custom path for Wardy data storage. Leave empty to use the default extension storage location."
    },
    "wardy.serverPort": {
      "type": "number",
      "default": 9876,
      "description": "Port for the Wardy HTTP API server. Set to 0 to disable."
    }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wardy-sidebar",
          "title": "Wardy",
          "icon": "src/wardy-icon.png"
        }
      ]
    },
    "views": {
      "wardy-sidebar": [
        {
          "type": "webview",
          "id": "wardy.sidebar",
          "name": "Wardy"
        }
      ]
    },
    "commands": [
      {
        "command": "wardy.settings",
        "title": "Wardy Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "wardy.settings",
          "when": "view == wardy.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "thesvg": "^3.0.18"
  }
}

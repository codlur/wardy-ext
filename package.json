{
  "name": "wardy",
  "displayName": "Wardy - The activity manager for your AI coding agents",
  "description": "Wardy - The activity manager for your AI coding agents",
  "version": "0.1.1",
  "publisher": "Wardy",
  "repository": {
    "type": "git",
    "url": "https://github.com/codlur/wardy-ext"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:wardy.sidebar"
  ],
  "icon": "src/wardylogo.png",
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Wardy",
      "properties": {
        "wardy.storagePath": {
          "type": "string",
          "default": "",
          "description": "Custom path for Wardy data storage. Leave empty to use the default extension storage location."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wardy-sidebar",
          "title": "Wardy",
          "icon": "src/wardy-icon.png"
        }
      ]
    },
    "views": {
      "wardy-sidebar": [
        {
          "type": "webview",
          "id": "wardy.sidebar",
          "name": "Wardy"
        }
      ]
    },
    "commands": [
      {
        "command": "wardy.login",
        "title": "Log in to Wardy Cloud"
      },
      {
        "command": "wardy.createAccount",
        "title": "Create Wardy Account"
      },
      {
        "command": "wardy.skip",
        "title": "Use Wardy with Local Data"
      },
      {
        "command": "wardy.settings",
        "title": "Wardy Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "wardy.settings",
          "when": "view == wardy.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "thesvg": "^3.0.18"
  }
}
